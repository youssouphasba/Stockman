{
  "info": {
    "_postman_id": "9b8f0531-6b89-4f5d-a5c4-5d8d2bde5c1a",
    "name": "Stockman API",
    "description": "Collection Postman pour tester les endpoints principaux de Stockman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://stockman-production-149d.up.railway.app"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "email",
      "value": ""
    },
    {
      "key": "password",
      "value": ""
    },
    {
      "key": "job_id",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data.access_token) { pm.collectionVariables.set('access_token', data.access_token); }",
                  "if (data.refresh_token) { pm.collectionVariables.set('refresh_token', data.refresh_token); }",
                  "pm.test('Tokens are stored', function () {",
                  "  pm.expect(pm.collectionVariables.get('access_token')).to.be.a('string').and.not.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "Refresh",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "refresh"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Refresh status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data.access_token) { pm.collectionVariables.set('access_token', data.access_token); }",
                  "if (data.refresh_token) { pm.collectionVariables.set('refresh_token', data.refresh_token); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Settings",
      "item": [
        {
          "name": "Get settings",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/settings",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "settings"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products?skip=0&limit=50",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products"
              ],
              "query": [
                {
                  "key": "skip",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Catalog import",
      "item": [
        {
          "name": "Parse import file",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/products/import/parse",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products",
                "import",
                "parse"
              ]
            }
          }
        },
        {
          "name": "Confirm import job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fileName\": \"catalogue.csv\",\n  \"importData\": [],\n  \"mapping\": {\n    \"name\": \"name\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/products/import/confirm",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products",
                "import",
                "confirm"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.job_id) { pm.collectionVariables.set('job_id', data.job_id); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get active import job",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products/import/jobs/active",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products",
                "import",
                "jobs",
                "active"
              ]
            }
          }
        },
        {
          "name": "Get import job by id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products/import/jobs/{{job_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products",
                "import",
                "jobs",
                "{{job_id}}"
              ]
            }
          }
        },
        {
          "name": "Resume import job",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/products/import/jobs/{{job_id}}/resume",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products",
                "import",
                "jobs",
                "{{job_id}}",
                "resume"
              ]
            }
          }
        }
      ]
    }
  ]
}
