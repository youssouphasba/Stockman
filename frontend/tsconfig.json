{
    "extends": "expo/tsconfig.base.json",
    "compilerOptions": {
        "strict": true,
        "lib": [
            "ESNext",
            "DOM"
        ],
        "paths": {
            "@/*": [
                "./*"
            ]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.d.ts",
        ".expo/types/**/*.ts",
        "expo-env.d.ts"
    ]
}
