{
  "expo": {
    "name": "Stockman",
    "slug": "stockman",
    "version": "1.0.17",
    "orientation": "default",
    "android": {
      "package": "com.youssouphasba.stockman",
      "versionCode": 17,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.youssouphasba.stockman",
      "buildNumber": "7",
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.849468181940-g1s18ifg1phcs1nc2ohqhk16fktogqi8"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Stockman uses the camera to scan product barcodes at checkout and in inventory, take photos of items to attach to product listings, and capture images of receipts or documents for record-keeping.",
        "NSMicrophoneUsageDescription": "Stockman uses the microphone to let you add products to the cart by speaking in the voice checkout, and to send voice messages in AI support.",
        "NSPhotoLibraryUsageDescription": "Stockman accesses your photo library so you can select an existing image to attach to a product listing, a receipt, or a business document.",
        "NSPhotoLibraryAddUsageDescription": "Stockman saves generated images to your photo library, such as receipts, product photos, or exported reports."
      },
      "locales": {
        "fr": "./locales/ios/fr.json",
        "ar": "./locales/ios/ar.json",
        "es": "./locales/ios/es.json",
        "de": "./locales/ios/de.json",
        "pt": "./locales/ios/pt.json",
        "it": "./locales/ios/it.json",
        "tr": "./locales/ios/tr.json",
        "ru": "./locales/ios/ru.json",
        "zh": "./locales/ios/zh.json",
        "hi": "./locales/ios/hi.json",
        "pl": "./locales/ios/pl.json",
        "ro": "./locales/ios/ro.json",
        "wo": "./locales/ios/wo.json",
        "ff": "./locales/ios/ff.json"
      }
    },
    "icon": "./assets/icon.png",
    "scheme": "stockman",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Stockman utilise la caméra pour scanner les codes-barres des produits, prendre des photos d’articles et joindre des images aux produits, ventes ou documents."
        }
      ],
      "expo-notifications",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-google-signin/google-signin",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Stockman utilise la caméra pour prendre une photo de produit, scanner un article ou joindre une image à une fiche ou à un document.",
          "photosPermission": "Stockman accède à votre photothèque pour sélectionner une image existante et l’ajouter à un produit, un reçu ou un document."
        }
      ],
      "expo-local-authentication",
      "expo-updates",
      ["expo-screen-orientation", { "initialOrientation": "DEFAULT" }],
      "expo-font",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "./plugins/withFirebaseModularHeaders",
      "expo-sharing",
      "expo-web-browser",
      [
        "expo-audio",
        {
          "microphonePermission": "Stockman uses the microphone to let you add products to the cart by speaking in the voice checkout, and to send voice messages in AI support."
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/83fa27c4-f1c0-45aa-9256-096ec479ced6"
    },
    "runtimeVersion": "1.0.0",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "83fa27c4-f1c0-45aa-9256-096ec479ced6"
      },
      "webAppUrl": "https://stockman.pro/app",
      "apiUrl": "https://stockman-production-149d.up.railway.app"
    }
  }
}
